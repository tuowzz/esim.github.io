  <style>
    :root{
      --bg:#0b0b0d;
      --card:#151518;
      --card-2:#1c1c20;
      --text:#ffffff;
      --muted:#b6b6c2;
      --line:rgba(255,255,255,0.08);
      --orange:#ff6b00;
      --orange-2:#ff8a1d;
      --shadow:0 18px 40px rgba(0,0,0,.35);
      --radius:22px;
      --max:1180px;
    }

    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{
      font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Noto Sans Thai",Arial,sans-serif;
      background:
        radial-gradient(circle at top right, rgba(255,107,0,.18), transparent 28%),
        radial-gradient(circle at top left, rgba(255,138,29,.1), transparent 20%),
        var(--bg);
      color:var(--text);
      line-height:1.6;
      padding-bottom:92px;
    }
    a{text-decoration:none;color:inherit}
    .container{width:100%;max-width:var(--max);margin:0 auto;padding:0 16px}

    .topbar{
      position:sticky;top:0;z-index:50;
      backdrop-filter: blur(10px);
      background:rgba(11,11,13,.75);
      border-bottom:1px solid var(--line);
    }
    .topbar-inner{
      display:flex;align-items:center;justify-content:space-between;
      padding:14px 0;
    }
    .brand{
      font-weight:900;font-size:20px;letter-spacing:.2px;
    }
    .brand span{color:var(--orange)}
    .top-cta{
      background:linear-gradient(135deg,var(--orange),var(--orange-2));
      color:#fff;
      padding:11px 16px;
      border-radius:14px;
      font-weight:800;
      font-size:14px;
      box-shadow:0 10px 24px rgba(255,107,0,.28);
    }

    .hero{padding:58px 0 30px}
    .hero-wrap{
      display:grid;
      grid-template-columns:1.12fr .88fr;
      gap:22px;
      align-items:stretch;
    }
    .hero-left,.hero-right{
      background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
      border:1px solid var(--line);
      border-radius:28px;
      box-shadow:var(--shadow);
    }
    .hero-left{padding:34px}
    .hero-right{
      padding:20px;
      display:flex;
      align-items:center;
      justify-content:center;
      min-height:380px;
      overflow:hidden;
      position:relative;
    }
    .hero-badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      background:rgba(255,107,0,.12);
      border:1px solid rgba(255,107,0,.25);
      color:#ffd7be;
      border-radius:999px;
      padding:8px 14px;
      font-size:14px;
      font-weight:700;
      margin-bottom:16px;
    }
    .hero h1{
      font-size:44px;
      line-height:1.08;
      font-weight:900;
      margin-bottom:14px;
    }
    .hero h1 .highlight{
      color:var(--orange);
      display:block;
    }
    .hero p{
      font-size:17px;
      color:var(--muted);
      max-width:720px;
      margin-bottom:18px;
    }
    .hero-points{
      display:flex;flex-wrap:wrap;gap:10px;
      margin-bottom:24px;
    }
    .hero-points span{
      border:1px solid var(--line);
      background:rgba(255,255,255,.03);
      color:#e7e7ec;
      padding:10px 13px;
      border-radius:999px;
      font-size:14px;
      font-weight:600;
    }
    .hero-actions{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
    }
    .btn-main{
      background:linear-gradient(135deg,var(--orange),var(--orange-2));
      color:#fff;
      padding:15px 22px;
      border-radius:16px;
      font-weight:900;
      font-size:16px;
      box-shadow:0 14px 28px rgba(255,107,0,.26);
    }
    .btn-ghost{
      background:rgba(255,255,255,.04);
      border:1px solid var(--line);
      color:#fff;
      padding:15px 22px;
      border-radius:16px;
      font-weight:800;
      font-size:16px;
    }

    .offer-box{
      width:100%;
      border-radius:24px;
      background:linear-gradient(180deg,#1b1b20,#131317);
      border:1px solid var(--line);
      padding:24px;
      position:relative;
      overflow:hidden;
    }
    .offer-title{
      font-size:18px;
      color:#ffd8c3;
      font-weight:900;
      margin-bottom:8px;
    }
    .offer-big{
      font-size:54px;
      line-height:1;
      font-weight:900;
      color:var(--orange);
      margin-bottom:10px;
    }
    .offer-desc{
      color:var(--muted);
      font-size:15px;
      margin-bottom:18px;
    }
    .offer-list{
      display:grid;
      gap:10px;
      margin-bottom:20px;
    }
    .offer-item{
      display:flex;
      gap:10px;
      align-items:flex-start;
      background:rgba(255,255,255,.03);
      border:1px solid var(--line);
      border-radius:16px;
      padding:12px 14px;
    }
    .offer-item b{display:block;margin-bottom:2px}
    .offer-item span{color:var(--muted);font-size:14px}
    .offer-cta{
      display:block;
      text-align:center;
      background:linear-gradient(135deg,var(--orange),var(--orange-2));
      border-radius:16px;
      padding:15px 18px;
      font-weight:900;
      font-size:16px;
      color:#fff;
    }

    .section{padding:24px 0 10px}
    .section-title{
      text-align:center;
      font-size:32px;
      font-weight:900;
      margin-bottom:8px;
    }
    .section-subtitle{
      text-align:center;
      color:var(--muted);
      max-width:800px;
      margin:0 auto 24px;
      font-size:16px;
    }

    .benefits{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:16px;
    }
    .benefit{
      background:linear-gradient(180deg,var(--card),var(--card-2));
      border:1px solid var(--line);
      border-radius:22px;
      padding:22px;
      box-shadow:var(--shadow);
    }
    .benefit .icon{
      width:50px;height:50px;border-radius:16px;
      display:flex;align-items:center;justify-content:center;
      background:rgba(255,107,0,.12);
      border:1px solid rgba(255,107,0,.2);
      font-size:24px;
      margin-bottom:14px;
    }
    .benefit h3{
      font-size:18px;
      margin-bottom:8px;
      font-weight:800;
    }
    .benefit p{
      color:var(--muted);
      font-size:14px;
    }

    .country-grid{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:20px;
    }
    .country-card{
      position:relative;
      background:linear-gradient(180deg,var(--card),var(--card-2));
      border:1px solid var(--line);
      border-radius:26px;
      padding:24px;
      box-shadow:var(--shadow);
      overflow:hidden;
    }
    .country-card:before{
      content:"";
      position:absolute;
      top:0;left:0;width:100%;height:5px;
      background:linear-gradient(90deg,var(--orange),var(--orange-2));
    }
    .country-head{
      display:flex;
      align-items:center;
      gap:12px;
      margin-bottom:12px;
    }
    .flag{
      font-size:34px;
    }
    .country-name{
      font-size:28px;
      font-weight:900;
      line-height:1.1;
    }
    .country-badge{
      display:inline-block;
      background:rgba(255,107,0,.12);
      border:1px solid rgba(255,107,0,.22);
      color:#ffd7be;
      padding:8px 12px;
      border-radius:999px;
      font-size:13px;
      font-weight:800;
      margin-bottom:14px;
    }
    .country-desc{
      color:var(--muted);
      font-size:15px;
      margin-bottom:14px;
      min-height:72px;
    }
    .features{
      list-style:none;
      display:grid;
      gap:8px;
      margin-bottom:16px;
    }
    .features li{
      padding:10px 12px;
      background:rgba(255,255,255,.03);
      border:1px solid var(--line);
      border-radius:14px;
      color:#eaeaf0;
      font-size:14px;
    }
    .price-box{
      background:#101014;
      border:1px solid var(--line);
      border-radius:18px;
      padding:16px;
      margin-bottom:16px;
    }
    .price-label{
      font-size:13px;
      color:var(--muted);
      margin-bottom:5px;
    }
    .price{
      font-size:32px;
      line-height:1;
      font-weight:900;
      margin-bottom:8px;
    }
    .price small{
      font-size:14px;
      color:var(--muted);
      font-weight:700;
    }
    .discount{
      color:#ffb37a;
      font-size:14px;
      font-weight:800;
    }
    .buy-btn{
      display:block;
      width:100%;
      text-align:center;
      background:linear-gradient(135deg,var(--orange),var(--orange-2));
      color:#fff;
      padding:16px 18px;
      border-radius:16px;
      font-size:17px;
      font-weight:900;
      box-shadow:0 14px 28px rgba(255,107,0,.24);
    }

    .steps{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:16px;
    }
    .step{
      background:linear-gradient(180deg,var(--card),var(--card-2));
      border:1px solid var(--line);
      border-radius:22px;
      padding:22px;
      box-shadow:var(--shadow);
      text-align:center;
    }
    .step-num{
      width:52px;height:52px;border-radius:50%;
      margin:0 auto 12px;
      display:flex;align-items:center;justify-content:center;
      font-size:19px;font-weight:900;
      background:linear-gradient(135deg,var(--orange),var(--orange-2));
      color:#fff;
    }
    .step h3{
      font-size:18px;
      margin-bottom:8px;
      font-weight:800;
    }
    .step p{
      font-size:14px;
      color:var(--muted);
    }

    .faq{
      max-width:920px;
      margin:0 auto;
      display:grid;
      gap:14px;
    }
    .faq-item{
      background:linear-gradient(180deg,var(--card),var(--card-2));
      border:1px solid var(--line);
      border-radius:18px;
      padding:18px 20px;
      box-shadow:var(--shadow);
    }
    .faq-item h4{
      font-size:17px;
      font-weight:800;
      margin-bottom:8px;
    }
    .faq-item p{
      color:var(--muted);
      font-size:15px;
    }

    .final-cta{
      background:linear-gradient(135deg,#1a1a1f,#101014);
      border:1px solid var(--line);
      border-radius:28px;
      padding:30px 22px;
      text-align:center;
      box-shadow:var(--shadow);
    }
    .final-cta h3{
      font-size:34px;
      font-weight:900;
      margin-bottom:10px;
    }
    .final-cta p{
      color:var(--muted);
      max-width:740px;
      margin:0 auto 18px;
    }
    .final-cta a{
      display:inline-block;
      background:linear-gradient(135deg,var(--orange),var(--orange-2));
      color:#fff;
      padding:15px 22px;
      border-radius:16px;
      font-weight:900;
      font-size:16px;
    }

    footer{
      padding:30px 0 26px;
      color:#8f8f9d;
      text-align:center;
      font-size:14px;
    }

    .floating-cta{
      position:fixed;
      left:12px;
      right:12px;
      bottom:12px;
      z-index:99;
      display:none;
    }
    .floating-cta a{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      width:100%;
      background:linear-gradient(135deg,var(--orange),var(--orange-2));
      color:#fff;
      border-radius:18px;
      padding:16px 18px;
      font-size:17px;
      font-weight:900;
      box-shadow:0 18px 38px rgba(255,107,0,.35);
    }

    @media (max-width: 1024px){
      .hero-wrap,.benefits,.country-grid,.steps{
        grid-template-columns:1fr 1fr;
      }
      .hero h1{font-size:36px}
      .country-name{font-size:24px}
    }

    @media (max-width: 768px){
      body{padding-bottom:96px}
      .top-cta{display:none}
      .hero{padding:28px 0 18px}
      .hero-wrap,.benefits,.country-grid,.steps{
        grid-template-columns:1fr;
      }
      .hero-left,.hero-right{padding:20px}
      .hero-right{min-height:auto}
      .hero h1{font-size:30px}
      .section-title{font-size:24px}
      .section-subtitle{font-size:15px}
      .country-card{padding:20px}
      .country-name{font-size:22px}
      .country-desc{min-height:auto}
      .price{font-size:28px}
      .final-cta h3{font-size:24px}
      .floating-cta{display:block}
    }
  </style>
</head>
<body>

  <div class="topbar">
    <div class="container topbar-inner">
      <div class="brand">Travel<span>eSIM</span></div>
      <a class="top-cta" href="#country-list">เลือกประเทศและสั่งซื้อ</a>
    </div>
  </div>

  <section class="hero">
    <div class="container">
      <div class="hero-wrap">
        <div class="hero-left">
          <div class="hero-badge">🔥 ใช้งานง่าย ไม่ต้องเปลี่ยนซิม</div>
          <h1>
            eSIM เที่ยวต่างประเทศ
            <span class="highlight">เลือกประเทศ แล้วกดซื้อได้เลย</span>
          </h1>
          <p>
            สำหรับคนที่กำลังจะเดินทางไปต่างประเทศและต้องการใช้งานอินเทอร์เน็ตทันที
            เลือกได้ 4 ประเทศยอดนิยม: ญี่ปุ่น เกาหลี ฮ่องกง และจีน
          </p>

          <div class="hero-points">
            <span>สแกน QR แล้วใช้งานได้</span>
            <span>ไม่ต้องหาซื้อซิมที่สนามบิน</span>
            <span>มีส่วนลด $5 ผ่านลิงก์นี้</span>
            <span>เหมาะกับ iPhone / Android ที่รองรับ eSIM</span>
          </div>

          <div class="hero-actions">
            <a class="btn-main" href="#country-list">ดูประเทศทั้งหมด</a>
            <a class="btn-ghost" href="#faq">ดูคำถามที่พบบ่อย</a>
          </div>
        </div>

        <div class="hero-right">
          <div class="offer-box">
            <div class="offer-title">ข้อเสนอจากลิงก์นายหน้า</div>
            <div class="offer-big">15%</div>
            <div class="offer-desc">
              รับค่าคอมมิชชัน 15% และลูกค้าได้รับส่วนลด $5 เมื่อสั่งซื้อผ่านลิงก์นี้
            </div>

            <div class="offer-list">
              <div class="offer-item">
                <div>💸</div>
                <div>
                  <b>ลูกค้าได้ส่วนลดทันที</b>
                  <span>ช่วยให้ตัดสินใจซื้อได้ง่ายขึ้น</span>
                </div>
              </div>
              <div class="offer-item">
                <div>📱</div>
                <div>
                  <b>ซื้อเองได้ง่าย</b>
                  <span>กดเลือกประเทศด้านล่างแล้วสั่งซื้อได้เลย</span>
                </div>
              </div>
              <div class="offer-item">
                <div>⚡</div>
                <div>
                  <b>เหมาะกับคนเดินทางด่วน</b>
                  <span>ไม่ต้องเสียเวลาหาซื้อซิมหลังลงเครื่อง</span>
                </div>
              </div>
            </div>

            <a class="offer-cta" href="#country-list">เริ่มเลือกประเทศเลย</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">ทำไมคนเดินทางถึงเลือก eSIM</h2>
      <p class="section-subtitle">
        เหมาะกับคนที่อยากลงเครื่องแล้วใช้งานเน็ตได้ทันที ไม่ต้องยุ่งกับซิมจริง และไม่ต้องเสียเวลาหาซื้อซิมในต่างประเทศ
      </p>

      <div class="benefits">
        <div class="benefit">
          <div class="icon">⚡</div>
          <h3>เปิดใช้งานเร็ว</h3>
          <p>เหมาะกับคนที่อยากเตรียมทุกอย่างให้พร้อมก่อนเดินทาง</p>
        </div>
        <div class="benefit">
          <div class="icon">🛫</div>
          <h3>เหมาะกับนักเดินทาง</h3>
          <p>ใช้ได้กับทริปสั้น ทริปยาว หรือเดินทางหลายเมือง</p>
        </div>
        <div class="benefit">
