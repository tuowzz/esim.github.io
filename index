  <script>
    const AFFILIATE_LINK = "https://www.superalink.com/destination/aff/M00000000";

    function trackCountryClick(countryEn, countryTh) {
      try {
        if (window.fbq) {
          fbq('track', 'InitiateCheckout', {
            content_name: 'eSIM ' + countryEn,
            content_category: 'eSIM',
            country: countryEn
          });
        }

        if (window.ttq) {
          ttq.track('InitiateCheckout', {
            contents: [{
              content_id: 'esim-' + countryEn.toLowerCase().replace(/\s+/g, '-'),
              content_type: 'product_group',
              content_name: 'eSIM ' + countryEn
            }],
            query: countryEn,
            value: 20,
            currency: 'USD'
          });
        }

        if (window.gtag) {
          gtag('event', 'begin_checkout', {
            currency: 'USD',
            value: 20,
            items: [{
              item_name: 'eSIM ' + countryEn,
              item_category: 'eSIM',
              item_variant: countryTh
            }]
          });

          gtag('event', 'click_country_buy', {
            event_category: 'eSIM',
            event_label: countryEn,
            value: 1
          });
        }
      } catch (e) {
        console.log('Tracking error:', e);
      }
    }

    document.querySelectorAll('.country-buy-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        const countryEn = this.dataset.country || '';
        const countryTh = this.dataset.countryTh || '';
        trackCountryClick(countryEn, countryTh);
      });
    });
  </script>
